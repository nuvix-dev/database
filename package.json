{
  "name": "@nuvix/db",
  "version": "0.3.0-bun.0",
  "description": "Modular and performant open source database library for Nuvix, with internal complexity abstracted from developers.",
  "license": "BSD-3-Clause",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "nuvix-db": "dist/cli/generate-types.js"
  },
  "scripts": {
    "build": "bun run build.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "rm -rf dist && bun run build && bun run typecheck",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "generate-types": "bun dist/cli/generate-types.js",
    "types:init": "bun dist/cli/generate-types.js --init",
    "types:watch": "bun dist/cli/generate-types.js --watch",
    "format": "prettier --write ."
  },
  "dependencies": {},
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nuvix-Tech/database.git"
  },
  "devDependencies": {
    "@nuvix/cache": "^1.0.3-alpha.1",
    "@types/bun": "latest",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">= 1.3.0"
  },
  "keywords": [
    "nuvix",
    "database",
    "typescript",
    "orm",
    "query-builder",
    "postgresql",
    "modular",
    "validation",
    "bun",
    "bun-native"
  ]
}
